# API environment configuration
# Copy this file to .env and replace each placeholder with your own values.

# Google Safe Browsing API
# How to obtain it: Create a Google Cloud project, enable the Google Safe Browsing API,
# and create an API key in Google Cloud Console > APIs & Services > Credentials.
# What it is used for: Validating URLs before shortening them to help detect phishing or malware.
SAFE_BROWSING_API_KEY=your_google_safe_browsing_api_key_here

# PostgreSQL database
# How to obtain it: Use a PostgreSQL connection string from services like Neon, Supabase,
# Railway, Render, or your own local Postgres instance.
# What it is used for: Connecting the API to the main database.
DATABASE_URL=postgresql://username:password@localhost:5432/url_shortener

# Redis
# How to obtain it: Run a local Redis instance or use a managed provider such as Upstash or Redis Cloud.
# What it is used for: Handling rate limiting and cache-related features.
HOST_REDIS=localhost
PASSWORD_REDIS=
PORT_REDIS=6379

# Server
# How to obtain it: Set this to the public URL where your API is served.
# What it is used for: Building callback and redirect URLs for the API.
PORT=3000
BASE_URL=http://localhost:3000
ORIGIN_URL=http://localhost:3000

# Authentication secret
# How to obtain it: Generate a long random string using a tool such as `openssl rand -hex 32`.
# What it is used for: Signing and verifying authentication sessions and tokens.
AUTH_SECRET=replace_with_a_long_random_secret

# Google OAuth
# How to obtain it: Create an OAuth Client ID in Google Cloud Console > APIs & Services > Credentials.
# What it is used for: Allowing users to sign in with their Google account.
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# GitHub OAuth
# How to obtain it: Create a GitHub OAuth App at https://github.com/settings/developers.
# What it is used for: Allowing users to sign in with their GitHub account.
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
