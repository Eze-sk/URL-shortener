---
import Layout from "@layouts/Layout.astro";
import Hero from "@components/astro/layout/Hero.astro";
import QuickActions from "@components/astro/ui/QuickActions.astro";
import BackdropHover from "@components/astro/ui/BackdropHover.astro";
---

<Layout lang="pt">
  <Hero />
  <QuickActions />
  <BackdropHover />
</Layout>

<script>
  import { WCToast } from "@components/wc/Toast.ts";
  import { WCAnimateSpin } from "@components/wc/AnimateSpin.ts";

  customElements.define("ws-toast", WCToast);
  customElements.define("ws-animate-spin", WCAnimateSpin);
</script>
