<div
  id="menu-backdrop"
  class="absolute bg-light-general/5 dark:bg-dark-general/5 backdrop-blur-lg rounded
    translate-x-[var(--left)] translate-y-[var(--top)]
    left-0 top-0
    w-[var(--width)] h-[var(--height)]
    transition-all duration-500
    ease-in-out opacity-0 -z-10"
>
</div>

<script is:inline>
  document.addEventListener("mouseover", (e) => {
    const el = e.target.closest("[data-backdrop]");
    if (!el) return;

    const menuBackdrop = document.querySelector("#menu-backdrop");
    if (!menuBackdrop) return;

    const { left, top, width, height } = el.getBoundingClientRect();

    menuBackdrop.style.setProperty("--left", `${left - 5}px`);
    menuBackdrop.style.setProperty("--top", `${top - 2.9}px`);
    menuBackdrop.style.setProperty("--width", `${width + 10}px`);
    menuBackdrop.style.setProperty("--height", `${height + 5}px`);

    menuBackdrop.style.opacity = "1";
    menuBackdrop.style.visibility = "visible";
  });

  document.addEventListener("mouseout", (e) => {
    const el = e.target.closest("[data-backdrop]");
    if (!el) return;

    const menuBackdrop = document.querySelector("#menu-backdrop");
    if (menuBackdrop) {
      menuBackdrop.style.opacity = "0";
      menuBackdrop.style.visibility = "hidden";
    }
  });
</script>
