---
import { LoginButton } from "@components/preact/auth/AuthButton.tsx";
import CustomizationSettings from "./CustomizationSettings.astro";
import LoginButtonSkeleton from "@components/astro/skeleton/LoginButtonSkeleton.astro";

import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const session = Astro.locals.session;
---

<section class="mt-10 flex flex-col">
  <form id="formShorten">
    <div class="flex gap-4 items-center">
      <div class="flex flex-col">
        <label for="originalUrl" class="text-ms font-light">
          {t("cardShortener.paste.label")}
        </label>
        <input
          type="text"
          name="originalUrl"
          id="originalUrl"
          placeholder={t("cardShortener.paste.label")}
          class="p-2 w-75 border rounded border-light-general dark:border-dark-general
            placeholder-gray-400 dark:placeholder-gray-500"
        />
      </div>

      <button
        type="submit"
        name="shortenBt"
        id="shortenBt"
        title={t("cardShortener.generated.label")}
        class="bg-light-general dark:bg-dark-general text-dark-general dark:text-light-general
          py-2.25 px-4 flex gap-1 self-end font-bold border-2 border-white rounded activeButton
          hover:border-light-general hover:dark:border-dark-general
          hover:text-light-general hover:dark:text-dark-general
          hover:bg-transparent transition-all duration-300"
      >
        <span class="shortenBt-text">{t("cardShortener.button")}</span>
        <svg
          class="shortenBt-svg"
          width="24"
          height="24"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
        >
          <path stroke="none" d="M0 0h24v24H0z"></path>
          <path d="M5 12h14M15 16l4-4M15 8l4 4"></path>
        </svg>
      </button>

      <div class="flex flex-col group">
        <span class="text-ms font-light"
          >{t("cardShortener.generated.label")}</span
        >
        <span
          class="p-2 relative flex items-center w-75 border rounded border-light-general dark:border-dark-general"
        >
          {
            session && (
              <label for="slug" class="sr-only">
                Add your custom slug
              </label>
            )
          }
          <span id="shortLink">
            http://ir-a.online/
            <span class={session ? "text-black" : "text-blue-700"} id="slug">
              my-link
            </span>
          </span>
          <button
            class="absolute right-2 group-hover:opacity-100 transition-opacity opacity-30"
            title="Copy link"
            id="copyLink"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
            >
              <path stroke="none" d="M0 0h24v24H0z"></path>
              <path
                d="M7 9.667A2.667 2.667 0 0 1 9.667 7h8.666A2.667 2.667 0 0 1 21 9.667v8.666A2.667 2.667 0 0 1 18.333 21H9.667A2.667 2.667 0 0 1 7 18.333z"
              ></path>
              <path
                d="M4.012 16.737A2 2 0 0 1 3 15V5c0-1.1.9-2 2-2h10c.75 0 1.158.385 1.5 1"
              ></path>
            </svg>
          </button>
        </span>
      </div>
    </div>
    <div class="flex justify-between mt-1">
      <small class="text-red-400 text-sm" id="errorMessage"></small>
      {
        session ? (
          <CustomizationSettings client:load />
        ) : (
          <LoginButton
            client:only="preact"
            content="Log in to personalize"
            style={{
              fontSize: "14px",
              fontWeight: 300,
            }}
          >
            <LoginButtonSkeleton slot="fallback" />
          </LoginButton>
        )
      }
    </div>
  </form>
</section>

<script>
  import { api } from "@lib/api.ts";
  import { ENDPOINT } from "@consts/config";
  import { urlScheme } from "@repo/schemes";
  import { toast } from "@components/wc/Toast.ts";

  const $formShorten = document.getElementById(
    "formShorten",
  ) as HTMLFormElement;
  const $inputUrl = document.getElementById("originalUrl") as HTMLInputElement;

  const $shortLink = document.getElementById("shortLink") as HTMLElement;
  const $copyLink = document.getElementById("copyLink") as HTMLButtonElement;

  const $errorMessage = document.getElementById("errorMessage") as HTMLElement;

  const $slug = document.getElementById("slug") as HTMLElement;

  $inputUrl.addEventListener("input", () => {
    $errorMessage.textContent = "";
  });

  $formShorten.addEventListener("submit", async (event) => {
    event.preventDefault();

    const buttonPress = event.submitter as HTMLButtonElement;

    if (!buttonPress || buttonPress.id !== "shortenBt") return;

    const form = event.target as HTMLFormElement;
    const shortenBtText = form.querySelector(
      ".shortenBt-text",
    ) as HTMLButtonElement;
    const shortenBtSvg = form.querySelector(
      ".shortenBt-svg",
    ) as HTMLButtonElement;
    const originalButtonText = shortenBtText.textContent;

    const data = new FormData(form);
    const originalUrl = data.get("originalUrl");

    const urlValidation = urlScheme.safeParse(originalUrl);

    if (!urlValidation.success) {
      $errorMessage.textContent = urlValidation.error!.issues[0].message;
      return;
    }

    try {
      shortenBtText.disabled = true;
      shortenBtText.innerHTML = "<ws-animate-spin><ws-animate-spin/>";
      shortenBtSvg.style.display = "none";

      const { data } = await api.post(ENDPOINT.create, {
        original_url: urlValidation.data,
      });

      const slugValue = data.resultCreatingURL.slug;

      if ($slug instanceof HTMLInputElement) {
        $slug.value = slugValue;
      } else {
        $slug.textContent = slugValue;
      }

      sessionStorage.setItem("slug", slugValue);
      sessionStorage.setItem("originalUrl", urlValidation.data);

      toast({
        message: "The URL has been successfully shortened!",
        position: "bottom-center",
        type: "success",
      });
    } catch (err) {
      console.error(err);
      toast({
        message: `Server error: ${err}`,
        position: "bottom-center",
        type: "error",
      });
    } finally {
      shortenBtText.disabled = false;
      shortenBtText.textContent = originalButtonText;
      shortenBtSvg.style.display = "flex";
    }
  });

  $copyLink.addEventListener("click", async () => {
    const children = Array.from($shortLink.childNodes);

    const linkParts = children.map((node) => {
      if (node instanceof HTMLElement) {
        if (node instanceof HTMLInputElement) {
          return node.value;
        }

        return node.textContent?.trim() || "";
      }

      return node.textContent?.trim() || "";
    });

    const link = linkParts.join("").replace(/\s+/g, "");

    try {
      await navigator.clipboard.writeText(link);
      toast({
        message: "URL copied",
        position: "bottom-center",
        type: "success",
      });
    } catch (err) {
      toast({
        message: `Error copying: ${err}`,
        position: "bottom-center",
        type: "error",
      });
    }
  });
</script>
