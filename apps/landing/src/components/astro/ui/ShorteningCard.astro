---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const session = Astro.locals.session;
---

<section class="mt-10 flex flex-col">
  <form id="formShorten">
    <div class="flex gap-4 items-center">
      <div class="flex flex-col">
        <label for="originalUrl" class="text-ms font-light">
          {t("shortener.paste.label")}
        </label>
        <input
          type="text"
          name="originalUrl"
          id="originalUrl"
          placeholder={t("shortener.paste.label")}
          class="p-2 w-75 border rounded border-light-general dark:border-dark-general
            placeholder-gray-400 dark:placeholder-gray-500"
        />
      </div>

      <button
        type="submit"
        name="shortenBt"
        id="shortenBt"
        title={t("shortener.generated.label")}
        class="bg-light-general dark:bg-dark-general text-dark-general dark:text-light-general
          py-2.25 px-4 flex gap-1 self-end font-bold border-2 border-white rounded activeButton
          hover:border-light-general hover:dark:border-dark-general
          hover:text-light-general hover:dark:text-dark-general
          hover:bg-transparent transition-all duration-300"
      >
        <span class="shortenBt-text">{t("shortener.button")}</span>
        <svg
          class="shortenBt-svg"
          width="24"
          height="24"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
        >
          <path stroke="none" d="M0 0h24v24H0z"></path>
          <path d="M5 12h14M15 16l4-4M15 8l4 4"></path>
        </svg>
      </button>

      <div class="flex flex-col group">
        <span class="text-ms font-light">{t("shortener.generated.label")}</span>
        <span
          class="p-2 relative flex items-center w-75 border rounded border-light-general dark:border-dark-general"
        >
          {
            session && (
              <label for="slug" class="sr-only">
                Add your custom slug
              </label>
            )
          }
          <span id="shortLink">
            http://ir-a.online/
            <span class={session ? "text-black" : "text-blue-700"} id="slug">
              my-link
            </span>
          </span>
          <button
            class="absolute right-2 group-hover:opacity-100 transition-opacity opacity-30"
            title="Copy link"
            id="copyLink"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
            >
              <path stroke="none" d="M0 0h24v24H0z"></path>
              <path
                d="M7 9.667A2.667 2.667 0 0 1 9.667 7h8.666A2.667 2.667 0 0 1 21 9.667v8.666A2.667 2.667 0 0 1 18.333 21H9.667A2.667 2.667 0 0 1 7 18.333z"
              ></path>
              <path
                d="M4.012 16.737A2 2 0 0 1 3 15V5c0-1.1.9-2 2-2h10c.75 0 1.158.385 1.5 1"
              ></path>
            </svg>
          </button>
        </span>
      </div>
    </div>
    <div class="flex justify-between mt-1">
      <small class="text-red-400 text-sm" id="errorMessage"></small>
    </div>
  </form>
</section>

